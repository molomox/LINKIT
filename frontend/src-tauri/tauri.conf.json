{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "L!nkyt",
  "version": "0.1.0",
  "identifier": "com.linkyt.desktop",
  "build": {
    "frontendDist": "http://localhost:3001",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": null
  },
  "app": {
    "windows": [
      {
        "title": "L!nkyt",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "notification": null
    }
  }

